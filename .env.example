# ============================================
# Frido Master Dashboard — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# JWT secret for token signing (use a strong random string in production)
JWT_SECRET=frido-dashboard-secret-change-in-production

# API server port
API_PORT=4000

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Azure Communication Services — Email
# Get this from Azure Portal → Communication Services → Keys
AZURE_EMAIL_CONNECTION_STRING=
# Verified sender address from Azure Email Communication Service
AZURE_EMAIL_SENDER=DoNotReply@myfrido.com
